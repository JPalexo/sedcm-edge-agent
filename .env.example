# ═══════════════════════════════════════════════════════════════════
#  SEDCM Edge Agent — Plantilla de configuración de Zona Invitada
#
#  1. Copia este archivo a  .env   (mismo directorio)
#  2. Ajusta MQTT_HOST con la IP del servidor central
#  3. Levanta los contenedores:  docker compose up -d
#
#  docker compose lee automáticamente el archivo .env de esta carpeta.
# ═══════════════════════════════════════════════════════════════════

# ── Conexión al broker MQTT (Servidor Central) ───────────────────
# IP de la máquina que corre el backend SEDCM en la red LAN.
# Pídesela al dueño del servidor central (ej. 192.168.1.75).
MQTT_HOST=192.168.1.75
MQTT_PORT=1883

# ── Identidad de esta Zona Invitada ──────────────────────────────
# Letra de zona asignada a esta máquina; NO puede repetirse en la LAN.
# El servidor central ocupa la Zona A → usa B, C, D, etc.
EDGE_ZONE=B

# Los racks se generan automáticamente como ${EDGE_ZONE}1 y ${EDGE_ZONE}2
# (ej. B1, B2). Los nodos se nombran ${EDGE_ZONE}N1 … ${EDGE_ZONE}N4
# (ej. BN1) para evitar colisiones de clave primaria entre zonas.

# ── Intervalos de publicación (opcional) ─────────────────────────
NODE_INTERVAL_S=5    # Segundos entre publicaciones de telemetría de nodo
ENV_INTERVAL_S=10    # Segundos entre publicaciones de telemetría ambiental
ACK_DELAY_S=0.5      # Segundos de espera antes de enviar ACK al backend
