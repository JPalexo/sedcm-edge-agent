# ═══════════════════════════════════════════════════════════════════
#  SEDCM Edge Agent — Configuración de la Zona Invitada
#  Copia este archivo a .env y ajusta los valores antes de levantar
#  los contenedores con:  docker compose up --build -d
# ═══════════════════════════════════════════════════════════════════

# ── Conexión al broker MQTT (Servidor Central) ───────────────────
# Reemplaza con la IP del servidor central en la red LAN.
# Ejemplo: la máquina del profesor tiene IP 192.168.1.75
MQTT_HOST=192.168.1.75
MQTT_PORT=1883

# ── Identidad de esta Zona Invitada ──────────────────────────────
# Letra de la zona asignada a esta máquina (no puede repetirse en la LAN).
# El servidor central ocupa la Zona A. Usa B, C, D, etc.
EDGE_ZONE=B

# Los racks se generan automáticamente como ${EDGE_ZONE}1 y ${EDGE_ZONE}2
# (ej. B1, B2). Los nodos se nombran N1–N4.

# ── Intervalos de publicación (opcional) ─────────────────────────
NODE_INTERVAL_S=5    # Segundos entre publicaciones de telemetría de nodo
ENV_INTERVAL_S=10    # Segundos entre publicaciones de telemetría ambiental
ACK_DELAY_S=0.5      # Segundos de espera antes de enviar ACK al backend
